# --- Cyber-Eden 宿主机配置模板 ---

# 1. 核心模型接口 (Google Gemini)
# 到 https://aistudio.google.com/app/apikey 获取
GOOGLE_API_KEY=YOUR_GOOGLE_AI_STUDIO_KEY

# 2. 核心路径定义 (绝对路径)
# 这是 Adam 模型物理存在的文件夹。大天使将挂载此地址。
ADAM_REPO_PATH=D:/work/AdamEden

# 3. 运行配置
GEMINI_MODEL=gemini-3.1-flash-lite-preview
ORACLE_PORT=8000
DEBUG=true
